# Copy this file to `.env` and fill in the values.

# Required: Discord bot token. Get one at https://discord.com/developers/applications
PI_BOT_TOKEN=

# Optional: default command prefix used when a server has not set its own (1-5 chars).
PI_BOT_DEFAULT_PREFIX=!

# Optional: directory for persisted JSON state. Defaults to ./data
# PI_BOT_DATA_DIR=data

# Optional: directory for log files. Defaults to ./logs
# PI_BOT_LOG_DIR=logs

# Optional: how often (seconds) the periodic saver flushes dirty state. Defaults to 60.
# PI_BOT_SAVE_INTERVAL=60

# Optional: log level for the application logger. Defaults to INFO.
# PI_BOT_LOG_LEVEL=INFO
