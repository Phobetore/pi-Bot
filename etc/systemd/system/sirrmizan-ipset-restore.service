[Unit]
Description=Restore SirrMizan ipsets at boot (permaban + threat-feed blocklist)
Before=fail2ban.service network-pre.target
DefaultDependencies=no
After=local-fs.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/local/bin/sirrmizan-ipset-restore.sh

[Install]
WantedBy=multi-user.target
